# Test scenario: user has Python + uv + git (happy path)
# Expected: full scaffolding works end to end

FROM python:3.11-slim

# install git + uv
RUN apt-get update && apt-get install -y git curl && rm -rf /var/lib/apt/lists/*
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:$PATH"

# copy project source and install fastapi-seed locally
WORKDIR /app
COPY . .
RUN pip install --quiet .

CMD ["fastapi-seed", "init", "test-project"]
